{
	"luci-mod-status-index": {
		"description": "LuCI Desktop theme: status overview RPC + UCI luci (fallback theme switch)",
		"read": {
			"ubus": {
				"luci": [
					"getCPUInfo",
					"getTempInfo",
					"getConntrackCount"
				]
			}
		},
		"write": {
			"uci": ["dhcp", "luci"],
			"ubus": {
				"uci": ["set", "commit"],
				"service": ["restart", "reload"]
			}
		}
	}
}
